# ============================================================
# Voice-First Lottery Platform — Environment Variables
# ============================================================
# Copy this file to `.env` (root, for tooling) and configure
# the equivalent secrets in Supabase Edge Function secrets:
#   supabase secrets set --env-file ./supabase/functions/.env
# Frontend variables (VITE_*) live in ./frontend/.env
# ============================================================

# ---------- Supabase ----------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Edge Functions ONLY. Never expose to frontend.

# ---------- Sola Payments ----------
SOLA_API_KEY=your-sola-api-key
SOLA_API_SECRET=your-sola-api-secret
SOLA_WEBHOOK_SECRET=your-sola-webhook-signing-secret
SOLA_MERCHANT_ID=your-sola-merchant-id
SOLA_ENVIRONMENT=sandbox                          # sandbox | production
SOLA_API_BASE_URL=https://api.solapayments.com    # override if needed

# ---------- SignalWire ----------
SIGNALWIRE_PROJECT_ID=your-project-id
SIGNALWIRE_API_TOKEN=your-api-token
SIGNALWIRE_SPACE_URL=your-space.signalwire.com
SIGNALWIRE_PHONE_NUMBER=+15555550100
SIGNALWIRE_WEBHOOK_SECRET=your-signalwire-signing-secret

# ---------- Email ----------
EMAIL_FROM=noreply@your-lottery.com
EMAIL_PROVIDER_KEY=your-email-provider-api-key

# ---------- App ----------
APP_URL=https://your-lottery.com
ADMIN_URL=https://admin.your-lottery.com

# ---------- Frontend (also mirror into ./frontend/.env with VITE_ prefix) ----------
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
# VITE_APP_URL=https://your-lottery.com
